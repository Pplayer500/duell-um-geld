# Backend Environment Variables
# Copy this file to .env and update values for your environment

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False

# Database Configuration
# For local development use SQLite:
# DATABASE_URL=sqlite:///./game.db

# For production with PostgreSQL (Railway):
# Railway will automatically set DATABASE_URL, but this is the format:
# DATABASE_URL=postgresql://user:password@host:port/database

# Redis (optional, for session caching)
# Redis not required for basic functionality
REDIS_URL=redis://localhost:6379

# Game Settings
MAX_PLAYERS_PER_GAME=100
MIN_PLAYERS_TO_START=2
SESSION_TIMEOUT_MINUTES=30
DISCONNECT_GRACE_PERIOD=30

# JWT Configuration
SECRET_KEY=your-secret-key-2024-change-in-production-very-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Host Authentication
HOST_PASSWORD=Passwort

# Frontend URL (for CORS)
FRONTEND_URL=https://duell-um-geld.vercel.app
