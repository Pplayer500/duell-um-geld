# Backend Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Security - CHANGE IN PRODUCTION!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production-use-32-chars

# Database - Railway automatically sets DATABASE_URL via PostgreSQL plugin
# Local development (SQLite): sqlite:///./game.db
# Production (PostgreSQL on Railway): Auto-set by plugin
DATABASE_URL=postgresql://user:password@localhost:5432/duell_um_geld

# Redis - Railway automatically sets REDIS_URL via Redis plugin  
# Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# CORS - IMPORTANT for production!
# Local: http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
# Production: Set in Railway ENV to your Vercel domain
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Game Settings
MAX_PLAYERS_PER_GAME=100
MIN_PLAYERS_TO_START=2

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend API URL - set in Vercel ENV
VITE_API_URL=http://localhost:8000
# Production (Vercel): https://duell-um-geld-production.up.railway.app

