# Backend Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# Database - Choose ONE of the following
# For local development (SQLite):
# DATABASE_URL=sqlite:///./game.db

# For production (PostgreSQL) - RECOMMENDED:
DATABASE_URL=postgresql://user:password@localhost:5432/duell_um_geld
# On Railway: DATABASE_URL=postgresql://user:password@host:5432/db_name

REDIS_URL=redis://localhost:6379
# On Railway: REDIS_URL=redis://:password@host:port

# CORS - for production, set to your domain(s)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost,http://127.0.0.1:5173

# Game Settings
MAX_PLAYERS_PER_GAME=100
MIN_PLAYERS_TO_START=2

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
SECRET_KEY=change-this-to-a-secure-random-string

# Frontend - Relative to where frontend is served from
VITE_API_URL=http://localhost:8000
# On Railway: VITE_API_URL=https://your-railway-domain.com
